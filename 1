-- ---------- 4. Sanity check on critical tables ----------
SELECT COUNT(*) AS robots            FROM [uipathpro].[dbo].[Robots];
SELECT COUNT(*) AS folders           FROM [uipathpro].[dbo].[OrganizationUnits];
SELECT COUNT(*) AS releases          FROM [uipathpro].[dbo].[Releases];
SELECT COUNT(*) AS packages          FROM [uipathpro].[dbo].[Packages];
SELECT COUNT(*) AS package_versions  FROM [uipathpro].[dbo].[PackageVersions];
