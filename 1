-- ============================================================
-- Orchestrator 2025 — post-upgrade verification queries
-- Fully-qualified [database].[schema].[table] form.
-- ============================================================

-- ---------- 1. Connectivity & version (any DB context) ----------
SELECT @@VERSION                          AS sql_version,
       @@SERVERNAME                       AS server_name,
       SERVERPROPERTY('ProductLevel')     AS patch_level,
       SERVERPROPERTY('Edition')          AS edition;

SELECT DB_NAME()    AS db_actual,
       SUSER_NAME() AS login_actual,
       USER_NAME()  AS user_en_bd;

-- ---------- 2. Failed SQL Agent jobs (last 7 days) ----------
-- Run with a DBA login (Orchestrator's login can't read msdb).
SELECT TOP 50
    j.name           AS job_name,
    h.run_date,
    h.run_time,
    h.run_status,    -- 0=fail, 1=success, 2=retry, 3=cancel, 4=in progress
    CASE h.run_status
        WHEN 0 THEN 'Failed'
        WHEN 1 THEN 'Succeeded'
        WHEN 2 THEN 'Retry'
        WHEN 3 THEN 'Canceled'
        WHEN 4 THEN 'In progress'
    END              AS status_text,
    h.step_name,
    h.message
FROM [msdb].[dbo].[sysjobs]        AS j
JOIN [msdb].[dbo].[sysjobhistory]  AS h ON j.job_id = h.job_id
WHERE h.run_status <> 1
  AND h.run_date >= CONVERT(int, CONVERT(varchar(8), DATEADD(day, -7, GETDATE()), 112))
ORDER BY h.run_date DESC, h.run_time DESC;

-- UiPath / Orchestrator-related jobs and whether they're enabled
SELECT name, enabled, description
FROM [msdb].[dbo].[sysjobs]
WHERE name LIKE '%UiPath%' OR name LIKE '%Orchestrator%';

-- ---------- 3. EF migrations — confirm 2025 schema is applied ----------
SELECT TOP 10 *
FROM [uipathpro].[dbo].[__EFMigrationsHistory]
ORDER BY MigrationId DESC;
-- Expected: top MigrationId starts with 2025...
